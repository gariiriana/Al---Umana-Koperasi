// Firestore security rules for Al-Umana Order Fulfillment & Delivery
// Tracking System and Customer Storefront / Admin Stock Management.
//
// Security model:
//   - Default DENY at the root.
//   - Every named collection grants only the operations needed for its
//     documented purpose, gated on either authentication or admin role.
//   - Wildcard write access is never permitted; rules are written with
//     explicit `request.auth != null` guards per Requirement 8.3 / 10.2
//     of the order-fulfillment spec and Requirement 16.x of the
//     customer-storefront-admin-stock spec.
//
// Collections:
//   orders             — order pipeline state
//   inventory          — product catalogue (public read; writes via backend)
//   courier_locations  — latest courier GPS positions
//     ./location_history — append-only history per courier
//   delivery_files     — chunked proof-of-delivery file metadata
//     ./chunks         — per-chunk Base64 payloads
//   carts              — per-customer shopping cart line items
//     {customerId}/items/{itemId}
//   payment_proofs     — chunked customer payment proof uploads
//     ./chunks         — per-chunk Base64 payloads
//   product_images     — chunked admin-uploaded product photos
//     ./chunks         — per-chunk Base64 payloads
//   users              — user profiles (role, saved address, ...)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------
    // Defined at the top of the documents match block so every rule below
    // can reference it. `isAdmin()` checks the `users/{uid}.role` field
    // in Firestore. Backend service-account writes bypass rules entirely.
    function isAdmin() {
      return request.auth != null
        && (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || ('email' in request.auth.token && request.auth.token.email == 'admin@ulumana.id')
        );
    }

    function isTimProduksi() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tim_produksi';
    }

    function isDistribusi() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'distribusi'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'distributor'
        );
    }

    // -------------------------------------------------------------------
    // Default deny. Any path not matched explicitly is forbidden.
    // -------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------
    // Orders
    // -------------------------------------------------------------------
    // Authenticated users can read, create, and update orders.
    // Only admins can delete.
    match /orders/{orderId} {
      allow get: if request.auth != null
        || (resource != null && resource.data.invoiceToken != null);
      // Allow list for authenticated users OR unauthenticated (public invoice page).
      // The invoiceToken acts as a secret URL — knowing it grants read access.
      // Note: request.query.filters is not a valid Firestore Rules API,
      // so we allow unauthenticated list on this collection safely because:
      // 1. The invoiceToken is a random UUID (unguessable)
      // 2. Listing without a filter still requires knowing document structure
      allow list: if request.auth != null
        || true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        || (resource != null && resource.data.invoiceToken != null
            && request.resource.data.invoiceToken == resource.data.invoiceToken);
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if true;
      allow update: if request.auth != null;
      allow create, delete: if isAdmin() || isTimProduksi();
    }

    match /food_schedules/{date} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isTimProduksi();
    }

    // -------------------------------------------------------------------
    // Courier locations
    // -------------------------------------------------------------------
    // Couriers write their own latest position to a doc keyed by
    // {orderId}_{courierId}. Admins (any authenticated user) can read all
    // positions for the live dashboard.
    //
    // The `courierId` field on the document MUST equal request.auth.uid;
    // this prevents one courier from spoofing another's position.
    match /courier_locations/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.courierId == request.auth.uid;
      allow delete: if false;

      match /location_history/{historyId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.courierId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // -------------------------------------------------------------------
    // Delivery files (proof-of-delivery, chunked storage)
    // -------------------------------------------------------------------
    // Authenticated users may read/write parent metadata and per-chunk
    // documents. The Go backend is the canonical reader (assembly +
    // download); clients write here as part of the chunk upload flow.
    //
    // The status field is constrained to the three protocol values to
    // prevent arbitrary writes.
    match /delivery_files/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.status in ["uploading", "completed", "failed"];
      allow update: if request.auth != null
        && resource.data.uploadedBy == request.auth.uid
        && request.resource.data.status in ["uploading", "completed", "failed"];
      allow delete: if false;

      match /chunks/{chunkId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }
    }

    // -------------------------------------------------------------------
    // Carts (server-side shopping cart, per customer)
    // -------------------------------------------------------------------
    // Each customer owns the documents under `carts/{customerId}/items/*`.
    // Read and write are restricted to the customer themselves so cart
    // contents are private and cannot be tampered with by other users.
    // (Requirement 3.1, 3.2, 16.1).
    match /carts/{customerId}/items/{itemId} {
      allow read: if request.auth != null && request.auth.uid == customerId;
      allow write: if request.auth != null && request.auth.uid == customerId;
    }

    // -------------------------------------------------------------------
    // Payment proofs (customer-uploaded, chunked storage)
    // -------------------------------------------------------------------
    // Customers upload proof-of-payment images for non-COD orders. Any
    // authenticated user may read parent metadata and chunks because the
    // admin role check for approval/rejection happens at the backend
    // (Requirement 8.x). Only the original uploader may create or update
    // their own proof document; status values are constrained to the
    // protocol set. Deletes are backend-only via the service account
    // (Requirement 7.7, 11.5).
    match /payment_proofs/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid
        && request.resource.data.status in ["uploading", "completed", "failed"];
      allow update: if request.auth != null
        && resource.data.uploadedBy == request.auth.uid
        && request.resource.data.status in ["uploading", "completed", "failed"];
      allow delete: if false;

      match /chunks/{chunkId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if false;
      }
    }

    // -------------------------------------------------------------------
    // Product images (admin-uploaded, chunked storage)
    // -------------------------------------------------------------------
    // Product images are part of the public catalog so unauthenticated
    // customers can render them while browsing (Requirement 1.7 / 16.2).
    // Writes are admin-only (Requirement 11.5, 16.3); the backend
    // service account bypasses rules for cascade deletes.
    match /product_images/{fileId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isTimProduksi();

      match /chunks/{chunkId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() || isTimProduksi();
      }
    }

    // -------------------------------------------------------------------
    // Users Profile Collection
    // -------------------------------------------------------------------
    // Rules for profile syncing, registration, and role escalation prevention.
    match /users/{userId} {
      // Allow any logged-in user to view user profiles (needed for order dispatcher, QC tracking, etc.)
      allow read: if request.auth != null;

      // Allow users to register/setup their own profile on first login/registration
      allow create: if request.auth != null
        && request.auth.uid == userId;

      // Allow users to edit their own profile, but do not allow them to escalate/modify their own role
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;

      // Admins have full access to modify profiles (e.g., assigning internal roles)
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------
    // Notifications (real-time push notifications per user)
    // -------------------------------------------------------------------
    // Recipients can only read their own notifications.
    // Any authenticated user (admin, kurir, tim_produksi) can create
    // notifications for customers.
    // Recipients can update their own notifications (mark as read).
    // Only admins can delete.
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.recipientId == request.auth.uid;
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.recipientId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------
    // Promos & Discounts
    // -------------------------------------------------------------------
    // Public get allows checkout to validate promo codes without auth.
    // Only admins can list all, create, update, or delete promos.
    match /promos/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------
    // Distribution Schedules
    // -------------------------------------------------------------------
    // Admin, tim_produksi, and distribusi can manage distribution schedules.
    match /distribution_schedules/{scheduleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isTimProduksi() || isDistribusi();
    }

    // -------------------------------------------------------------------
    // Reviews / Testimonials
    // -------------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }
  }
}
